pipeline {
    agent any

    options {
        timestamps()
    }

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Тег образа (передаёт CI при вызове этого job)')
    }

    environment {
        DOCKERHUB_USER = "${env.DOCKERHUB_USER ?: 'YOUR_DOCKERHUB_LOGIN'}"
        IMAGE = "${DOCKERHUB_USER}/devops1-api"
        SCENARIO_BASE_URL = "http://127.0.0.1:8000"
        // Postgres creds инжектятся в .env как jenkins credential (pg-creds). Никаких паролей в коде.
    }

    stages {
        stage('checkout_repo') {
            steps {
                checkout scm
            }
        }

        stage('docker_login_pull') {
            steps {
                sh 'docker --version'
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DH_USER',
                        passwordVariable: 'DH_PASS'
                    )
                ]) {
                    sh '''
                        set -e
                        echo "$DH_PASS" | docker login -u "$DH_USER" --password-stdin
                    '''
                }
                sh "docker pull ${IMAGE}:${params.IMAGE_TAG}"
                sh "docker tag ${IMAGE}:${params.IMAGE_TAG} devops1-api:latest"
            }
        }

        stage('compose_up') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'pg-creds',
                        usernameVariable: 'POSTGRES_USER',
                        passwordVariable: 'POSTGRES_PASSWORD'
                    )
                ]) {
                    sh '''
                        set -e
                        cat > .env <<EOF
POSTGRES_DB=devops
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
EOF
                        docker compose down -v || true
                        docker compose up -d
                        sleep 25
                    '''
                }
            }
        }

        stage('seed_db') {
            steps {
                sh '''
                    set -e
                    docker compose exec -T api python scripts/seed_db.py || echo "seed_db skipped (нет data/raw/data.csv в образе)"
                '''
            }
        }

        stage('functional_scenarios') {
            steps {
                sh '''
                    set -e
                    export SCENARIO_BASE_URL="http://127.0.0.1:8000"
                    python3 scripts/run_scenarios.py || python scripts/run_scenarios.py
                '''
            }
        }
    }

    post {
        always {
            sh 'docker compose logs --no-color > compose-logs.txt 2>&1 || true'
            archiveArtifacts artifacts: 'compose-logs.txt', allowEmptyArchive: true
            sh 'docker compose down -v || true'
            sh 'rm -f .env || true'
        }
        failure {
            echo 'Проверь: docker compose на агенте, credentials dockerhub-creds и pg-creds, свободные порты 8000/5432.'
        }
    }
}
